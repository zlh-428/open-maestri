      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These are the install locations of Maestri skills — they are key to agents understanding and using Maestri features."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些是 Maestri 技能的安装位置 — 它们是智能体理解并使用 Maestri 各项功能的关键。"
          }
        }
      }
    },
