    "agent.onboarding.drag_hint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag a terminal node from the top toolbar, choose Claude Code / Codex / Shell and more"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从顶部工具栏拖入终端节点，选择 Claude Code / Codex / Shell 等预设"
          }
        }
      }
    },
    "agent.role.footer": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Roles provide initial instructions for terminals. Maestro can assign roles when recruiting sub-agents."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "角色为终端提供初始指令。Maestro 招募子 Agent 时可指定角色。"
          }
        }
      }
    },
    "agent.role.inject_hint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After assigning a role, the following content will be written to CLAUDE.md / AGENTS.md"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分配角色后，以下内容将写入 CLAUDE.md / AGENTS.md 文件"
