    "agents.roles.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create roles with specific instructions for your agents. Once assigned to a terminal, agents will automatically follow these instructions."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为你的代理创建包含具体指令的角色。分配到终端后，代理会自动遵循这些指令。"
          }
        }
      }
    },
    "agents.roles.search": {
      "localizations": {
        "en": {
          "stringUnit": {
